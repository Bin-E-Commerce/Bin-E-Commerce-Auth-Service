# Runtime
NODE_ENV=development
PORT=3001
APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:5173

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bin_auth

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092

# Keycloak public/client auth
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=bin-ecommerce
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=replace-with-client-secret
KEYCLOAK_WEB_CLIENT_ID=web-client

# Keycloak admin client
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=replace-with-admin-client-secret
